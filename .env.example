# LLM Providers
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Intent Prediction Model (fast/cheap)
INTENT_MODEL=groq/llama-3.1-8b-instant

# Generation Model (main)
GENERATION_MODEL=groq/llama-3.3-70b-versatile

# Memory Extraction Model
EXTRACTION_MODEL=groq/llama-3.1-8b-instant

# Qdrant Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Neo4j Graph DB
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Memory Settings
ENABLE_MEMORY=true
DEDUP_THRESHOLD=0.85

# Server
HOST=0.0.0.0
PORT=8000

# Bot Configs Directory
CONFIGS_DIR=configs
