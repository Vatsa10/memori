# LLM Providers
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Intent Prediction Model (fast/cheap)
INTENT_MODEL=groq/llama-3.1-8b-instant

# Generation Model (main)
GENERATION_MODEL=groq/llama-3.3-70b-versatile

# Qdrant Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Embedding Model (for intent similarity)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Server
HOST=0.0.0.0
PORT=8000

# Bot Configs Directory
CONFIGS_DIR=configs
